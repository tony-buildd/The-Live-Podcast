# Convex deployment URL (from `npx convex dev` or Convex dashboard)
NEXT_PUBLIC_CONVEX_URL="https://your-deployment.convex.cloud"

# Clerk authentication (from Clerk dashboard)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_replace_me"
CLERK_SECRET_KEY="sk_test_replace_me"

# Optional: route customization for Clerk hosted pages/components
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/auth/signin"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/auth/signup"

# LLM Provider — "openai" or "ollama"
LLM_PROVIDER="ollama"

# Ollama configuration (required if LLM_PROVIDER="ollama")
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.1"

# OpenAI configuration (required if LLM_PROVIDER="openai")
OPENAI_API_KEY=""

# Optional: OpenAI embedding key for higher-quality semantic search
# If unset, the app uses a deterministic local fallback embedding.
OPENAI_EMBEDDINGS_API_KEY=""
