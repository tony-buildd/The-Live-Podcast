# Database — SQLite file path (relative to project root)
DATABASE_URL="file:./prisma/dev.db"

# LLM Provider — "openai" or "ollama"
LLM_PROVIDER="ollama"

# Ollama configuration (required if LLM_PROVIDER="ollama")
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.1"

# OpenAI configuration (required if LLM_PROVIDER="openai")
OPENAI_API_KEY=""

# NextAuth.js (required for authentication in milestone 5)
NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="http://localhost:3100"
